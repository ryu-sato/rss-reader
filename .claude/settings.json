{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Write(.claude/rules/*)",
      "Write(.claude/settings.json)",
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Write(.claude/*)",
      "Write(.next/*)",
      "Write(.pnpm-store/*)",
      "Write(node_modules/*)",
      "Write(.env)",
      "Write(pnpm-lock.yaml)",
      "Write(skills-lock.json)"
    ],
    "ask": [
      "Write(.agents/*)",
      "Bash(rm*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "tsumiki@tsumiki": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false
  },
  "skills": {
    "enabled": true,
    "paths": [
      ".claude/skills"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
