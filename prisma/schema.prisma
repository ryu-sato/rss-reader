// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Feed {
  id            String    @id @default(uuid())
  url           String    @unique
  title         String
  description   String?
  faviconUrl    String?
  memo          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastFetchedAt DateTime?

  entries       Entry[]

  @@map("feeds")
}

model Entry {
  id          String     @id @default(uuid())
  feedId      String
  guid        String
  title       String
  link        String
  description String?
  content     String?
  imageUrl    String?
  publishedAt DateTime?
  effectedDate DateTime  @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  feed        Feed       @relation(fields: [feedId], references: [id], onDelete: Cascade)
  meta        EntryMeta?
  tags        EntryTag[]
  scores      EntryPreferenceScore[]

  @@unique([feedId, guid])
  @@index([publishedAt(sort: Desc)])
  @@index([feedId])
  @@map("entries")
}

model EntryMeta {
  id           String   @id @default(uuid())
  entryId      String   @unique
  isRead       Boolean  @default(false)
  isReadLater  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entry        Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("entry_metas")
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())

  entries   EntryTag[]

  @@map("tags")
}

model EntryTag {
  entryId String
  tagId   String

  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
  @@index([tagId])
  @@map("entry_tags")
}

model Digest {
  id        String   @id @default(uuid())
  title     String?
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("digests")
}

model UserPreference {
  id        String   @id @default(uuid())
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scores    EntryPreferenceScore[]

  @@map("user_preferences")
}

model EntryPreferenceScore {
  id           String   @id @default(uuid())
  entryId      String
  preferenceId String
  score        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entry        Entry          @relation(fields: [entryId], references: [id], onDelete: Cascade)
  preference   UserPreference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)

  @@unique([entryId, preferenceId])
  @@index([entryId])
  @@index([preferenceId])
  @@map("entry_preference_scores")
}
